# Server Configuration
# PORT=5000
# NODE_ENV=development
# SESSION_SECRET=your-secure-secret-key-change-in-production

# Database
# MONGODB_URL=mongodb://localhost:27017/universityhub

# Public URL of the SPA (CORS + links in signup/reset emails). In production use your real HTTPS site
# — wrong values break “verify email” and “reset password” links inside messages.

# Administrator bootstrap / invitations
# Comma-separated emails (existing users) promoted to role "admin" on server start:
# ADMIN_EMAILS=you@university.edu,colleague@university.edu
# Invite key for /admin/signup when an administrator already exists:
# ADMIN_REGISTRATION_SECRET=long-random-string
# Deprecated legacy alias (only if ADMIN_EMAILS empty): STAFF_EMAILS

# Google OAuth (optional)# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Email (Gmail SMTP — enable 2-Step Verification, then create an App Password on that account).
# Use your official outbound mailbox so users see university email in notification messages.
# EMAIL_USER=university.students.hub.et1@gmail.com
# EMAIL_PASS=your-app-password
# EMAIL_FROM="University Student Hub <university.students.hub.et1@gmail.com>"

# Session cookie secure flag (HTTPS/production)
# SESSION_COOKIE_SECURE=true

# Rate limits: window ms (default 900000), max requests per window
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_REGISTER_MAX=5
# RATE_LIMIT_FORGOT_MAX=5
# RATE_LIMIT_RESEND_MAX=5

# AWS S3 (optional, for file uploads)
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=your-bucket-name
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Gemini AI (required for Liqu AI chat and exam question extraction)
# Get a free key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-google-gemini-api-key
# GEMINI_MODEL_ID=gemini-2.0-flash
# GEMINI_EMBED_MODEL_ID=text-embedding-004

# MongoDB Atlas vector index for RAG retrieval
# RAG_VECTOR_INDEX_NAME=book_chunks_vector_index
